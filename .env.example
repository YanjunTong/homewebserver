# HomeMedia Hub 环境配置示例
# 复制此文件为 .env 并修改相应的配置

# ==================== 媒体文件夹配置 ====================

# 图片文件夹路径
# 应用将扫描此文件夹中的所有图片文件
# 支持的格式: .jpg, .jpeg, .png
IMAGE_FOLDER=/home/yanjun/media/images

# 视频文件夹路径
# 应用将扫描此文件夹中的所有视频文件
# 支持的格式: .mp4, .mkv
VIDEO_FOLDER=/home/yanjun/media/videos

# ==================== 应用配置 ====================

# 应用名称
APP_NAME=HomeMedia Hub

# 应用版本
APP_VERSION=1.0.0

# 调试模式 (true 或 false)
# 启用时：会显示更详细的日志和错误信息
# 禁用时：生产环境建议设为 false
DEBUG=true

# ==================== 数据库配置 ====================

# 数据库 URL
# 当前配置使用 SQLite，文件为 media.db
# 若需使用其他数据库，修改此 URL
DATABASE_URL=sqlite+aiosqlite:///./media.db
